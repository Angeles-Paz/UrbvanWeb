<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="https://jakarta.ee/xml/ns/jakartaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="https://jakarta.ee/xml/ns/jakartaee
         https://jakarta.ee/xml/ns/jakartaee/web-app_5_0.xsd"
         version="5.0">

    <display-name>Urbvan</display-name>
    <description>Sistema web de transporte urbano - CDMX</description>

    <!-- ============================================================
         FILTRO DE SESIÓN — protege todas las rutas por rol
         ============================================================ -->
    <filter>
        <filter-name>FiltroSesion</filter-name>
        <filter-class>mx.urbvan.util.FiltroSesion</filter-class>
    </filter>
    <filter-mapping>
        <filter-name>FiltroSesion</filter-name>
        <url-pattern>/*</url-pattern>
    </filter-mapping>

    <!-- ============================================================
         SERVLETS DE AUTENTICACIÓN
         ============================================================ -->
    <servlet>
        <servlet-name>LoginServlet</servlet-name>
        <servlet-class>mx.urbvan.servlet.auth.LoginServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>LoginServlet</servlet-name>
        <url-pattern>/login</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>RegistroServlet</servlet-name>
        <servlet-class>mx.urbvan.servlet.auth.RegistroServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>RegistroServlet</servlet-name>
        <url-pattern>/registro</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>LogoutServlet</servlet-name>
        <servlet-class>mx.urbvan.servlet.auth.LogoutServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>LogoutServlet</servlet-name>
        <url-pattern>/logout</url-pattern>
    </servlet-mapping>

    <!-- ============================================================
         SERVLETS DE PASAJERO
         ============================================================ -->
    <servlet>
        <servlet-name>SolicitarViajeServlet</servlet-name>
        <servlet-class>mx.urbvan.servlet.pasajero.SolicitarViajeServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>SolicitarViajeServlet</servlet-name>
        <url-pattern>/pasajero/solicitar</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>CancelarViajeServlet</servlet-name>
        <servlet-class>mx.urbvan.servlet.pasajero.CancelarViajeServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>CancelarViajeServlet</servlet-name>
        <url-pattern>/pasajero/cancelar</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>CalificarServlet</servlet-name>
        <servlet-class>mx.urbvan.servlet.pasajero.CalificarServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>CalificarServlet</servlet-name>
        <url-pattern>/pasajero/calificar</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>PagoServlet</servlet-name>
        <servlet-class>mx.urbvan.servlet.pasajero.PagoServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>PagoServlet</servlet-name>
        <url-pattern>/pasajero/pago</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>EstadoViajeServlet</servlet-name>
        <servlet-class>mx.urbvan.servlet.pasajero.EstadoViajeServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>EstadoViajeServlet</servlet-name>
        <url-pattern>/pasajero/estado-viaje</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>HistorialServlet</servlet-name>
        <servlet-class>mx.urbvan.servlet.pasajero.HistorialServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>HistorialServlet</servlet-name>
        <url-pattern>/pasajero/historial</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>DashboardPasajeroServlet</servlet-name>
        <servlet-class>mx.urbvan.servlet.pasajero.DashboardPasajeroServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>DashboardPasajeroServlet</servlet-name>
        <url-pattern>/pasajero/dashboard</url-pattern>
    </servlet-mapping>

    <!-- ============================================================
         SERVLETS DE OPERADOR
         ============================================================ -->
    <servlet>
        <servlet-name>PanelOperadorServlet</servlet-name>
        <servlet-class>mx.urbvan.servlet.operador.PanelOperadorServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>PanelOperadorServlet</servlet-name>
        <url-pattern>/operador/panel</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>ViajeActivoServlet</servlet-name>
        <servlet-class>mx.urbvan.servlet.operador.ViajeActivoServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>ViajeActivoServlet</servlet-name>
        <url-pattern>/operador/viaje-activo</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>ResponderSolicitudServlet</servlet-name>
        <servlet-class>mx.urbvan.servlet.operador.ResponderSolicitudServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>ResponderSolicitudServlet</servlet-name>
        <url-pattern>/operador/responder</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>ActualizarPosicionServlet</servlet-name>
        <servlet-class>mx.urbvan.servlet.operador.ActualizarPosicionServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>ActualizarPosicionServlet</servlet-name>
        <url-pattern>/operador/posicion</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>CambiarEstadoViajeServlet</servlet-name>
        <servlet-class>mx.urbvan.servlet.operador.CambiarEstadoViajeServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>CambiarEstadoViajeServlet</servlet-name>
        <url-pattern>/operador/cambiar-estado</url-pattern>
    </servlet-mapping>

    <!-- ============================================================
         SERVLETS DE ADMINISTRADOR
         ============================================================ -->
    <servlet>
        <servlet-name>DashboardAdminServlet</servlet-name>
        <servlet-class>mx.urbvan.servlet.admin.DashboardAdminServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>DashboardAdminServlet</servlet-name>
        <url-pattern>/admin/dashboard</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>GestionUsuariosServlet</servlet-name>
        <servlet-class>mx.urbvan.servlet.admin.GestionUsuariosServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>GestionUsuariosServlet</servlet-name>
        <url-pattern>/admin/usuarios</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>GestionOperadoresServlet</servlet-name>
        <servlet-class>mx.urbvan.servlet.admin.GestionOperadoresServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>GestionOperadoresServlet</servlet-name>
        <url-pattern>/admin/operadores</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>GestionVehiculosServlet</servlet-name>
        <servlet-class>mx.urbvan.servlet.admin.GestionVehiculosServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>GestionVehiculosServlet</servlet-name>
        <url-pattern>/admin/vehiculos</url-pattern>
    </servlet-mapping>

    <!-- ============================================================
         CONFIGURACIÓN GENERAL
         ============================================================ -->
    <!-- Página de inicio -->
    <welcome-file-list>
        <welcome-file>index.jsp</welcome-file>
    </welcome-file-list>

    <!-- Página de error 404 -->
    <error-page>
        <error-code>404</error-code>
        <location>/index.jsp</location>
    </error-page>

    <!-- Tiempo de sesión: 30 minutos de inactividad -->
    <session-config>
        <session-timeout>30</session-timeout>
    </session-config>

</web-app>
